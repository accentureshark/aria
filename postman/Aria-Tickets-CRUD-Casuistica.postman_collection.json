    {
      "name": "Create Ticket Minimal (201 - defaults)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('ticketMinimalId', body.id);",
              "pm.test('status default OPEN', function () { pm.expect(body.status).to.eql('OPEN'); });",
              "pm.test('priority default MEDIUM', function () { pm.expect(body.priority).to.eql('MEDIUM'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Ticket minimo\",\n  \"description\": \"Sin relaciones\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] }
      }
    },
    {
      "name": "Create Ticket With Relations (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('ticketMainId', body.id);",
              "pm.test('reporter anidado', function () { pm.expect(body.reporter.id).to.eql(Number(pm.collectionVariables.get('ticketReporterId'))); });",
              "pm.test('assignee anidado', function () { pm.expect(body.assignee.id).to.eql(Number(pm.collectionVariables.get('ticketAssigneeId'))); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Bug login\",\n  \"description\": \"No permite autenticar\",\n  \"priority\": \"HIGH\",\n  \"reporterId\": {{ticketReporterId}},\n  \"assigneeId\": {{ticketAssigneeId}}\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] }
      }
    },
    {
      "name": "Create Ticket Validation Error (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 400', function () { pm.response.to.have.status(400); });",
              "const body = pm.response.json();",
              "pm.test('fieldErrors presente', function () { pm.expect(body.fieldErrors).to.be.an('array').that.is.not.empty; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/tickets", "host": ["{{baseUrl}}"], "path": ["api", "tickets"] }
      }
    },
    {
      "name": "Create Ticket Invalid Reporter (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 404', function () { pm.response.to.have.status(404); });",
              "const body = pm.response.json();",
              "pm.test('mensaje not found', function () { pm.expect(body.message).to.include('Person not found'); });"
            ]
