{
  "info": {
    "_postman_id": "e3ce1c16-75ad-458c-b3e8-e5ed9545a661",
    "name": "Aria - Tickets CRUD Casuistica",
    "description": "Cobertura CRUD y casos de error para /api/tickets incluyendo relaciones por IDs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup - Create Reporter Person (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('ticketReporterUsername', `ticket_reporter_${suffix}`);",
              "pm.collectionVariables.set('ticketReporterEmail', `ticket_reporter_${suffix}@aria.dev`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('ticketReporterId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{ticketReporterUsername}}\",\n  \"email\": \"{{ticketReporterEmail}}\",\n  \"fullName\": \"Ticket Reporter\",\n  \"department\": \"Engineering\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/persons", "host": ["{{baseUrl}}"], "path": ["api", "persons"] }
      }
    },
    {
      "name": "Setup - Create Assignee Person (201)",
