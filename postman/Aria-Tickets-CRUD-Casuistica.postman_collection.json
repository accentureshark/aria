    {
      "name": "Get Ticket By Id (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('id coincide', function () { pm.expect(body.id).to.eql(Number(pm.collectionVariables.get('ticketMainId'))); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketMainId}}", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketMainId}}"] }
      }
    },
    {
      "name": "Update Ticket (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('status actualizado', function () { pm.expect(body.status).to.eql('IN_PROGRESS'); });",
              "pm.test('priority actualizado', function () { pm.expect(body.priority).to.eql('URGENT'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Bug login actualizado\",\n  \"description\": \"Analisis en progreso\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"URGENT\",\n  \"reporterId\": {{ticketReporterId}},\n  \"assigneeId\": {{ticketAssigneeId}}\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketMainId}}", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketMainId}}"] }
      }
    },
