        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{ticketAssigneeUsername}}\",\n  \"email\": \"{{ticketAssigneeEmail}}\",\n  \"fullName\": \"Ticket Assignee\",\n  \"department\": \"QA\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/persons", "host": ["{{baseUrl}}"], "path": ["api", "persons"] }
      }
