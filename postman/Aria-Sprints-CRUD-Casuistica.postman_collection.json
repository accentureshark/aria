  "info": {
    "_postman_id": "b7c4e2a1-3f88-4d12-9e01-7a2b5c8d9f10",
    "name": "Aria - Sprints CRUD Casuistica",
    "description": "Cobertura CRUD y casos de error para /api/sprints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/sprints - Crear sprint (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('sprintName', `Sprint Test ${Date.now()}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('response tiene id', function () { pm.expect(body.id).to.be.a('number'); });",
              "pm.test('name coincide', function () { pm.expect(body.name).to.eql(pm.collectionVariables.get('sprintName')); });",
              "pm.test('status default es PLANNED', function () { pm.expect(body.status).to.eql('PLANNED'); });",
              "pm.test('createdAt presente', function () { pm.expect(body.createdAt).to.not.be.null; });",
              "pm.collectionVariables.set('sprintId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{sprintName}}\",\n  \"goal\": \"Implementar modulo de autenticacion\",\n  \"startDate\": \"2025-02-01\",\n  \"endDate\": \"2025-02-14\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/sprints",
          "host": ["{{baseUrl}}"],
          "path": ["api", "sprints"]
        }
      }
    },
    {
      "name": "GET /api/sprints - Listar todos (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('response es array', function () { pm.expect(body).to.be.an('array'); });",
              "pm.test('contiene al menos un sprint', function () { pm.expect(body.length).to.be.greaterThan(0); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sprints",
          "host": ["{{baseUrl}}"],
          "path": ["api", "sprints"]
        }
      }
    },
    {
      "name": "GET /api/sprints?status=PLANNED - Filtrar por status (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('response es array', function () { pm.expect(body).to.be.an('array'); });",
              "pm.test('todos los sprints son PLANNED', function () {",
              "  body.forEach(s => pm.expect(s.status).to.eql('PLANNED'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sprints?status=PLANNED",
          "host": ["{{baseUrl}}"],
          "path": ["api", "sprints"],
          "query": [{ "key": "status", "value": "PLANNED" }]
        }
      }
    },
