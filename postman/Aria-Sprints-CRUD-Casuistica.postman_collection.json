    {
      "name": "PUT /api/sprints/:id - Actualizar sprint (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('status actualizado a ACTIVE', function () { pm.expect(body.status).to.eql('ACTIVE'); });",
              "pm.test('goal actualizado', function () { pm.expect(body.goal).to.eql('Goal actualizado'); });",
              "pm.test('updatedAt presente', function () { pm.expect(body.updatedAt).to.not.be.null; });"
            ]
          }
        }
      ],
      "request": {
