{
  "name": "aria-postman-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Colecciones Postman para validar la casuistica CRUD de Aria con Newman",
  "scripts": {
    "test:persons": "newman run Aria-Persons-CRUD-Casuistica.postman_collection.json -e Aria-local.postman_environment.json --reporters cli",
    "test:tickets": "newman run Aria-Tickets-CRUD-Casuistica.postman_collection.json -e Aria-local.postman_environment.json --reporters cli",
    "test:sprints": "newman run Aria-Sprints-CRUD-Casuistica.postman_collection.json -e Aria-local.postman_environment.json --reporters cli,htmlextra --reporter-htmlextra-export reports/sprints-report.html",
    "test:all": "npm run test:persons && npm run test:tickets && npm run test:sprints"
  },
  "devDependencies": {
    "newman": "^6.1.3",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}

