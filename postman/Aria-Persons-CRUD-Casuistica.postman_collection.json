    {
      "name": "Update Person (200)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('reporterUpdatedUsername', `reporter_updated_${suffix}`);",
