{
  "info": {
    "_postman_id": "6a852e49-1265-4543-aa4f-7d6ca2dcf2d1",
    "name": "Aria - Persons CRUD Casuistica",
    "description": "Cobertura CRUD y casos de error para /api/persons",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup - Create Reporter Person (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('reporterUsername', `reporter_${suffix}`);",
              "pm.collectionVariables.set('reporterEmail', `reporter_${suffix}@aria.dev`);",
              "pm.collectionVariables.set('reporterName', `Reporter ${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('reporterId', body.id);",
              "pm.test('id generado', function () { pm.expect(body.id).to.be.a('number'); });",
              "pm.test('active true por default', function () { pm.expect(body.active).to.eql(true); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{reporterUsername}}\",\n  \"email\": \"{{reporterEmail}}\",\n  \"fullName\": \"{{reporterName}}\",\n  \"department\": \"Engineering\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/persons", "host": ["{{baseUrl}}"], "path": ["api", "persons"] }
      }
    },
    {
      "name": "Create Duplicate Person (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 409', function () { pm.response.to.have.status(409); });",
              "const body = pm.response.json();",
              "pm.test('error de conflicto', function () { pm.expect(body.error).to.eql('Conflict'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{reporterUsername}}\",\n  \"email\": \"{{reporterEmail}}\",\n  \"fullName\": \"Duplicado\",\n  \"department\": \"Engineering\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/persons", "host": ["{{baseUrl}}"], "path": ["api", "persons"] }
      }
    },
    {
      "name": "Create Person Validation Error (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 400', function () { pm.response.to.have.status(400); });",
              "const body = pm.response.json();",
              "pm.test('fieldErrors presente', function () { pm.expect(body.fieldErrors).to.be.an('array').that.is.not.empty; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"\",\n  \"email\": \"mail-invalido\",\n  \"fullName\": \"\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/persons", "host": ["{{baseUrl}}"], "path": ["api", "persons"] }
      }
    },
