  },
  "item": [
    {
      "name": "POST /api/backlogs - Crear backlog (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('backlogName', `Product Backlog ${Date.now()}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('response tiene id', function () { pm.expect(body.id).to.be.a('number'); });",
              "pm.test('name coincide', function () { pm.expect(body.name).to.eql(pm.collectionVariables.get('backlogName')); });",
              "pm.test('description presente', function () { pm.expect(body.description).to.eql('Tickets pendientes de priorizar'); });",
              "pm.test('createdAt presente', function () { pm.expect(body.createdAt).to.not.be.null; });",
              "pm.test('updatedAt presente', function () { pm.expect(body.updatedAt).to.not.be.null; });",
              "pm.collectionVariables.set('backlogId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{backlogName}}\",\n  \"description\": \"Tickets pendientes de priorizar\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/backlogs",
          "host": ["{{baseUrl}}"],
          "path": ["api", "backlogs"]
        }
      }
    },
    {
      "name": "GET /api/backlogs - Listar todos (200)",
      "event": [
