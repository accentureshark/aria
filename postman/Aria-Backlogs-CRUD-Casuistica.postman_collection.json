          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('response es array', function () { pm.expect(body).to.be.an('array'); });",
              "pm.test('contiene al menos un backlog', function () { pm.expect(body.length).to.be.greaterThan(0); });"
            ]
          }
        }
